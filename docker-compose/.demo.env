##### registries
IMAGE_REGISTRY_DOCKER_IO=
IMAGE_REGISTRY_GHCR_IO=

#### fhir-to-server
FHIR_AUTH_BASIC_ENABLED=
FHIR_AUTH_BASIC_PASSWORD=
FHIR_AUTH_BASIC_USERNAME=

##### fhir-server
FHIR_URL=
# TOPIC=fhir.pseudonymized.obds.bundles
TOPIC=

##### fhir-to-delta
AWS_ACCESS_KEY_ID=admin
AWS_SECRET_ACCESS_KEY=miniopass
# Set this to the Kafka topic name(s) that fhir-to-delta should consume; if you use multiple topics, provide them as a comma-separated list (for example: topic1,topic2).
FHIR_TO_DELTA_KAFKA_TOPICS=fhir.pseudonymized.obds.bundles

##### analytics-on-fhir
LOCATION=test
SPARK_DRIVER_MEMORY=
STUDY_NAME=dq
FHIR_PATIENT_IDENTIFIER_SYSTEM=https://bzkf.github.io/obds-to-fhir/identifiers/patient-id

# obds-to-fhir
FHIR_SYSTEMS_IDENTIFIERS_BASE_URL=
FHIR_SYSTEMS_IDENTIFIERS_PATIENT_ID=
OBDS_TO_FHIR_INPUT_DIRECTORY=./demo-obds-reports/
OBDS_TO_FHIR_OUTPUT_DIRECTORY=./output-obds-reports/

# Default: ./anonymization.yaml
FHIR_PSEUDONYMIZER_ANONYMIZATION_FILE_PATH=./anonymization-demo.yaml
##### pseudonymization
FHIR_PSEUDONYMIZER_CRYPTO_HASH_KEY=arandomstring
FHIR_PSEUDONYMIZER_PSEUDONYMIZATION_SERVICE=None

##### trino-pathling
HIVE_METASTORE_DB_PASSWORD=hive
